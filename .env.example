# Copy this file to .env (local dev) or set these as environment variables
# in your Hostinger hosting panel (hPanel → Node.js app → Environment variables).

# SMTP credentials for the mailbox that SENDS the contact-form notification.
# If you created sales@westestimating.com as a mailbox in Hostinger's email
# hosting, these are typically:
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=sales@westestimating.com
SMTP_PASS=your-mailbox-password

# Where contact-form submissions are delivered (usually the same address).
CONTACT_TO=sales@westestimating.com

# Public site URL, used for sitemap.xml / SEO metadata / structured data.
NEXT_PUBLIC_SITE_URL=https://westestimating.com
